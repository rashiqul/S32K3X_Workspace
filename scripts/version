#!/bin/bash
# Version script for S32K3x Workspace
# Returns the current version based on git tags

set -e

# Get version from git describe if in a git repo
if git rev-parse --git-dir > /dev/null 2>&1; then
    # Use git describe to get version
    VERSION=$(git describe --tags --always --dirty 2>/dev/null || echo "0.1.0-dev")
    echo "$VERSION"
else
    # Default version if not in git repo
    echo "0.1.0"
fi
